#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_integer_dot_product : require
#extension GL_EXT_control_flow_attributes : enable

// Q8_0 dp4a MoE variant: weights × Q8_1 input using dotPacked4x8EXT (dp4a).
// 128 threads = 4 subgroups, each subgroup handles one row.
// gl_WorkGroupID.y = expert slot (0..n_used-1).

layout(local_size_x = 128) in;

struct block_q8_0 {
    float16_t d;
    int8_t qs[32];
};
struct block_q8_0_p16 {
    float16_t d;
    int16_t qs[16];
};

struct block_q8_1 {
    float16_t d;
    float16_t s;
    int32_t qs[8];
};

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(scalar, set = 0, binding = 1) readonly buffer A { block_q8_0 data_a[]; };
layout(scalar, set = 0, binding = 1) readonly buffer AP16 { block_q8_0_p16 data_a_p16[]; };
layout(scalar, set = 0, binding = 2) readonly buffer B { block_q8_1 data_b[]; };
layout(set = 0, binding = 3) readonly buffer Indices { float expert_indices[]; };

layout(push_constant) uniform Params {
    int rows;
    int cols;
    int expert_stride;
    int base_offset;
    int shared_input;
};

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint sub_id = tid >> 5;
    uint sub_tid = tid & 31u;
    uint slot = gl_WorkGroupID.y;
    uint row = gl_WorkGroupID.x * 4u + sub_id;

    if (row >= uint(rows)) return;

    int eidx = int(expert_indices[slot]);
    uint expert_offset = uint(base_offset) + uint(eidx) * uint(expert_stride);

    uint ncols = uint(cols);
    uint bpr = ncols >> 5;
    uint num_q8_blocks = ncols >> 5;
    uint q8_off = (shared_input != 0) ? 0u : (slot * num_q8_blocks);
    uint b_qs_idx = sub_tid & 3u;

    uint num_iters = ncols / 256u;
    if (num_iters * 256u + 8u * sub_tid < ncols) num_iters++;
    uint unrolled = num_iters & ~3u;

    float acc0 = 0.0, acc1 = 0.0, acc2 = 0.0, acc3 = 0.0;
    uint i = 0;

    while (i < unrolled) {
        [[unroll]] for (uint k = 0; k < 4u; k++) {
            uint col = (i + k) * 256u + 8u * sub_tid;
            uint a_ib = expert_offset + row * bpr + (col >> 5);
            uint b_ib = q8_off + (col >> 5);

            float da = float(data_a[a_ib].d);
            vec2 dsb = vec2(float(data_b[b_ib].d), float(data_b[b_ib].s));

            int32_t a_qs0 = pack32(i16vec2(data_a_p16[a_ib].qs[b_qs_idx * 4],
                                           data_a_p16[a_ib].qs[b_qs_idx * 4 + 1]));
            int32_t a_qs1 = pack32(i16vec2(data_a_p16[a_ib].qs[b_qs_idx * 4 + 2],
                                           data_a_p16[a_ib].qs[b_qs_idx * 4 + 3]));

            int32_t b_qs0 = data_b[b_ib].qs[b_qs_idx * 2];
            int32_t b_qs1 = data_b[b_ib].qs[b_qs_idx * 2 + 1];

            int32_t q_sum = dotPacked4x8EXT(a_qs0, b_qs0) + dotPacked4x8EXT(a_qs1, b_qs1);
            float r = float(q_sum) * da * dsb.x;

            if (k == 0u) acc0 += r; else if (k == 1u) acc1 += r;
            else if (k == 2u) acc2 += r; else acc3 += r;
        }
        i += 4u;
    }
    while (i < num_iters) {
        uint col = i * 256u + 8u * sub_tid;
        uint a_ib = expert_offset + row * bpr + (col >> 5);
        uint b_ib = q8_off + (col >> 5);

        float da = float(data_a[a_ib].d);
        vec2 dsb = vec2(float(data_b[b_ib].d), float(data_b[b_ib].s));

        int32_t a_qs0 = pack32(i16vec2(data_a_p16[a_ib].qs[b_qs_idx * 4],
                                       data_a_p16[a_ib].qs[b_qs_idx * 4 + 1]));
        int32_t a_qs1 = pack32(i16vec2(data_a_p16[a_ib].qs[b_qs_idx * 4 + 2],
                                       data_a_p16[a_ib].qs[b_qs_idx * 4 + 3]));

        int32_t b_qs0 = data_b[b_ib].qs[b_qs_idx * 2];
        int32_t b_qs1 = data_b[b_ib].qs[b_qs_idx * 2 + 1];

        int32_t q_sum = dotPacked4x8EXT(a_qs0, b_qs0) + dotPacked4x8EXT(a_qs1, b_qs1);
        acc0 += float(q_sum) * da * dsb.x;
        i++;
    }

    float acc = subgroupAdd(acc0 + acc1 + acc2 + acc3);
    if (sub_tid == 0u) out_data[slot * uint(rows) + row] = acc;
}
