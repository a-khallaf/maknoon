#version 450

// Rotary Position Embedding using precomputed cos/sin tables.
// Supports both standard (interleaved) and neox (split-half) modes.
// Tables encode all RoPE variant details (basic, YaRN, NTK, etc.)
// so the shader is agnostic to the frequency scheme.
// One workgroup per head, threads iterate over rotation pairs.

layout(local_size_x = 128) in;

layout(set = 0, binding = 0) buffer Q { float q_data[]; };
layout(set = 0, binding = 1) buffer K { float k_data[]; };
layout(set = 0, binding = 2) buffer CosTable { float cos_table[]; };
layout(set = 0, binding = 3) buffer SinTable { float sin_table[]; };

layout(push_constant) uniform Params {
    int num_heads;
    int num_kv_heads;
    int head_dim;
    int rope_dim;
    int pos;
    int neox;
};

void main() {
    uint head = gl_WorkGroupID.x;
    uint pos_id = gl_WorkGroupID.y;
    uint tid = gl_LocalInvocationID.x;
    int rd = rope_dim > 0 ? rope_dim : head_dim;
    int half_dim = rd / 2;

    if (int(tid) >= half_dim) return;

    int actual_pos = pos + int(pos_id);
    uint q_stride = uint(num_heads) * uint(head_dim);
    uint k_stride = uint(num_kv_heads) * uint(head_dim);

    int table_base = actual_pos * half_dim + int(tid);
    float cos_val = cos_table[table_base];
    float sin_val = sin_table[table_base];

    if (neox != 0) {
        if (head < num_heads) {
            uint base = pos_id * q_stride + head * uint(head_dim);
            float q0 = q_data[base + tid];
            float q1 = q_data[base + tid + uint(half_dim)];
            q_data[base + tid] = q0 * cos_val - q1 * sin_val;
            q_data[base + tid + uint(half_dim)] = q0 * sin_val + q1 * cos_val;
        }
        if (head < num_kv_heads) {
            uint base = pos_id * k_stride + head * uint(head_dim);
            float k0 = k_data[base + tid];
            float k1 = k_data[base + tid + uint(half_dim)];
            k_data[base + tid] = k0 * cos_val - k1 * sin_val;
            k_data[base + tid + uint(half_dim)] = k0 * sin_val + k1 * cos_val;
        }
    } else {
        if (head < num_heads) {
            uint base = pos_id * q_stride + head * uint(head_dim);
            float q0 = q_data[base + 2 * tid];
            float q1 = q_data[base + 2 * tid + 1];
            q_data[base + 2 * tid] = q0 * cos_val - q1 * sin_val;
            q_data[base + 2 * tid + 1] = q0 * sin_val + q1 * cos_val;
        }
        if (head < num_kv_heads) {
            uint base = pos_id * k_stride + head * uint(head_dim);
            float k0 = k_data[base + 2 * tid];
            float k1 = k_data[base + 2 * tid + 1];
            k_data[base + 2 * tid] = k0 * cos_val - k1 * sin_val;
            k_data[base + 2 * tid + 1] = k0 * sin_val + k1 * cos_val;
        }
    }
}
