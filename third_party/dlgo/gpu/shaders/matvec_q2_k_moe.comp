#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_control_flow_attributes : enable

// Q2_K MoE variant: processes n_used experts in one dispatch.

layout(local_size_x = 128) in;

struct block_q2_k {
    uint8_t scales[16];
    uint8_t qs[64];
    float16_t d;
    float16_t dmin;
};

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(scalar, set = 0, binding = 1) readonly buffer Weights { block_q2_k blocks[]; };
layout(set = 0, binding = 2) readonly buffer X { float x_data[]; };
layout(set = 0, binding = 3) buffer Indices { float expert_indices[]; };

layout(push_constant) uniform Params {
    int rows;
    int cols;
    int expert_stride;
    int base_offset;
    int shared_input;
};

#define NUM_ROWS 2
shared float tmpsh[NUM_ROWS][4];

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint first_row = gl_WorkGroupID.x * uint(NUM_ROWS);
    uint slot = gl_WorkGroupID.y;

    uint ncols = uint(cols);
    uint num_sb = ncols >> 8;

    uint num_rows = uint(NUM_ROWS);
    if (first_row + num_rows > uint(rows)) {
        num_rows = uint(rows) - first_row;
        if (first_row >= uint(rows)) return;
    }

    int eidx = int(expert_indices[slot]);
    uint expert_offset = uint(base_offset) + uint(eidx) * uint(expert_stride);
    uint pos_x_off = (shared_input != 0) ? 0u : (slot * ncols);

    uint lane = tid & 31u;
    uint sb_group = tid >> 5;

    float temp[NUM_ROWS];
    [[unroll]] for (int r = 0; r < NUM_ROWS; r++) temp[r] = 0.0;

    bool hi = lane >= 16u;

    for (uint b = sb_group; b < num_sb; b += 4u) {
        int x_block = int(b) * 256;

        [[unroll]] for (uint n = 0; n < NUM_ROWS; n++) {
            uint bi = expert_offset + (first_row + n) * num_sb + b;
            float d_all = float(blocks[bi].d);
            float dmin  = float(blocks[bi].dmin);

            float acc = 0.0;

            [[unroll]] for (int n128 = 0; n128 < 2; n128++) {
                int q_base = n128 * 32;
                int x_base = x_block + n128 * 128;

                [[unroll]] for (int j = 0; j < 4; j++) {
                    int scale_idx = n128 * 8 + j * 2 + (hi ? 1 : 0);
                    uint sc = uint(blocks[bi].scales[scale_idx]);
                    float dl = d_all * float(sc & 0xFu);
                    float ml = dmin  * float(sc >> 4u);

                    uint q_byte = uint(blocks[bi].qs[q_base + int(lane)]);
                    uint q_val  = (q_byte >> uint(j * 2)) & 3u;

                    int x_idx = int(pos_x_off) + x_base + j * 32 + int(lane);
                    acc += (dl * float(q_val) - ml) * x_data[x_idx];
                }
            }
            temp[n] += acc;
        }
    }

    [[unroll]] for (int r = 0; r < NUM_ROWS; r++) {
        temp[r] = subgroupAdd(temp[r]);
    }

    if (gl_SubgroupInvocationID == 0u) {
        [[unroll]] for (int r = 0; r < NUM_ROWS; r++) {
            tmpsh[r][gl_SubgroupID] = temp[r];
        }
    }
    barrier();

    if (tid == 0u) {
        [[unroll]] for (uint n = 0; n < num_rows; n++) {
            float sum = 0.0;
            [[unroll]] for (uint s = 0; s < gl_NumSubgroups; s++) {
                sum += tmpsh[n][s];
            }
            out_data[slot * uint(rows) + first_row + n] = sum;
        }
    }
}
