#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_control_flow_attributes : enable

// 128 threads = 4 subgroups. Each subgroup handles one row.
// 4x outer loop unrolling.
// MoE variant: processes n_used experts in one dispatch.

layout(local_size_x = 128) in;

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(set = 0, binding = 1) readonly buffer W { vec4 w_v4[]; };
layout(set = 0, binding = 2) readonly buffer X { vec4 x_v4[]; };
layout(set = 0, binding = 3) buffer Indices { float expert_indices[]; };

layout(push_constant) uniform Params {
    int rows;
    int cols;
    int expert_stride;
    int base_offset;
    int shared_input;
};

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint sub_id = tid >> 5;
    uint sub_tid = tid & 31u;
    uint row = gl_WorkGroupID.x * 4u + sub_id;

    if (row >= uint(rows)) return;

    uint ncols = uint(cols);
    uint slot = gl_WorkGroupID.y;
    int eidx = int(expert_indices[slot]);
    uint expert_offset = uint(base_offset) + uint(eidx) * uint(expert_stride);
    uint x_off = (shared_input != 0) ? 0u : slot * (ncols >> 2);
    uint out_off = slot * uint(rows);
    uint row_off = expert_offset + row * (ncols >> 2);

    uint num_iters = ncols / 256u;
    if (num_iters * 256u + 8u * sub_tid < ncols) num_iters++;
    uint unrolled = num_iters & ~3u;

    float acc0 = 0.0, acc1 = 0.0, acc2 = 0.0, acc3 = 0.0;
    uint i = 0;

    while (i < unrolled) {
        [[unroll]] for (uint k = 0; k < 4u; k++) {
            uint col = (i + k) * 256u + 8u * sub_tid;
            uint idx = col >> 2;
            float r = dot(x_v4[x_off + idx], w_v4[row_off + idx]) + dot(x_v4[x_off + idx + 1u], w_v4[row_off + idx + 1u]);
            if (k == 0u) acc0 += r; else if (k == 1u) acc1 += r;
            else if (k == 2u) acc2 += r; else acc3 += r;
        }
        i += 4u;
    }
    while (i < num_iters) {
        uint col = i * 256u + 8u * sub_tid;
        uint idx = col >> 2;
        acc0 += dot(x_v4[x_off + idx], w_v4[row_off + idx]) + dot(x_v4[x_off + idx + 1u], w_v4[row_off + idx + 1u]);
        i++;
    }

    float acc = subgroupAdd(acc0 + acc1 + acc2 + acc3);
    if (sub_tid == 0u) out_data[out_off + row] = acc;
}
