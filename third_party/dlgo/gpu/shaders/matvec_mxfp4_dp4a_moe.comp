#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_integer_dot_product : require
#extension GL_EXT_control_flow_attributes : enable

layout(local_size_x = 128) in;

struct block_q8_1 {
    float16_t d;
    float16_t s;
    int32_t qs[8];
};

struct block_mxfp4 {
    uint8_t e;
    uint8_t qs[16];
};

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(scalar, set = 0, binding = 1) readonly buffer A { block_mxfp4 data_a[]; };
layout(scalar, set = 0, binding = 2) readonly buffer B { block_q8_1 data_b[]; };
layout(set = 0, binding = 3) readonly buffer Indices { float expert_indices[]; };

layout(push_constant) uniform Params {
    int rows;
    int cols;
    int expert_stride;
    int base_offset;
    int shared_input;
};

const int8_t kvalues_c[16] = int8_t[16](
    int8_t(0), int8_t(1), int8_t(2), int8_t(3), int8_t(4), int8_t(6), int8_t(8), int8_t(12),
    int8_t(0), int8_t(-1), int8_t(-2), int8_t(-3), int8_t(-4), int8_t(-6), int8_t(-8), int8_t(-12)
);
shared int8_t kvalues[16];

float e8m0_to_f32(uint e) {
    if (e < 2u) return uintBitsToFloat(0x00200000u << e);
    return uintBitsToFloat((e - 1u) << 23u);
}

int32_t pack_kvalues(uint packed_nibbles) {
    return int32_t(
        uint32_t(uint8_t(kvalues[packed_nibbles & 0xFu])) |
        (uint32_t(uint8_t(kvalues[(packed_nibbles >> 8u) & 0xFu])) << 8u) |
        (uint32_t(uint8_t(kvalues[(packed_nibbles >> 16u) & 0xFu])) << 16u) |
        (uint32_t(uint8_t(kvalues[(packed_nibbles >> 24u) & 0xFu])) << 24u)
    );
}

void main() {
    uint tid = gl_LocalInvocationID.x;

    if (tid < 16u) kvalues[tid] = kvalues_c[tid];
    barrier();

    uint sub_id = tid >> 5u;
    uint sub_tid = tid & 31u;
    uint slot = gl_WorkGroupID.y;
    uint row = gl_WorkGroupID.x * 4u + sub_id;

    if (row >= uint(rows)) return;

    int eidx = int(expert_indices[slot]);
    uint expert_offset = uint(base_offset) + uint(eidx) * uint(expert_stride);

    uint ncols = uint(cols);
    uint bpr = ncols >> 5u;
    uint num_q8_blocks = ncols >> 5u;
    uint q8_off = (shared_input != 0) ? 0u : (slot * num_q8_blocks);
    uint b_qs_idx = sub_tid & 3u;

    uint num_iters = ncols / 256u;
    if (num_iters * 256u + 8u * sub_tid < ncols) num_iters++;
    uint unrolled = num_iters & ~3u;

    float acc0 = 0.0, acc1 = 0.0, acc2 = 0.0, acc3 = 0.0;
    uint i = 0;

    while (i < unrolled) {
        [[unroll]] for (uint k = 0; k < 4u; k++) {
            uint col = (i + k) * 256u + 8u * sub_tid;
            uint a_blk = expert_offset + row * bpr + (col >> 5u);
            uint b_ib = q8_off + (col >> 5u);

            float da = e8m0_to_f32(uint(data_a[a_blk].e));

            uint qs_off = b_qs_idx * 4u;
            uint32_t qs_packed = pack32(u8vec4(
                data_a[a_blk].qs[qs_off],
                data_a[a_blk].qs[qs_off + 1u],
                data_a[a_blk].qs[qs_off + 2u],
                data_a[a_blk].qs[qs_off + 3u]
            ));
            int32_t a_lo = pack_kvalues(qs_packed & 0x0F0F0F0Fu);
            int32_t a_hi = pack_kvalues((qs_packed >> 4u) & 0x0F0F0F0Fu);

            float dsb_x = float(data_b[b_ib].d);
            int32_t b_qs0 = data_b[b_ib].qs[b_qs_idx];
            int32_t b_qs1 = data_b[b_ib].qs[b_qs_idx + 4u];

            int32_t q_sum = dotPacked4x8EXT(a_lo, b_qs0) + dotPacked4x8EXT(a_hi, b_qs1);
            float r = da * float(q_sum) * dsb_x;

            if (k == 0u) acc0 += r; else if (k == 1u) acc1 += r;
            else if (k == 2u) acc2 += r; else acc3 += r;
        }
        i += 4u;
    }
    while (i < num_iters) {
        uint col = i * 256u + 8u * sub_tid;
        uint a_blk = expert_offset + row * bpr + (col >> 5u);
        uint b_ib = q8_off + (col >> 5u);

        float da = e8m0_to_f32(uint(data_a[a_blk].e));

        uint qs_off = b_qs_idx * 4u;
        uint32_t qs_packed = pack32(u8vec4(
            data_a[a_blk].qs[qs_off],
            data_a[a_blk].qs[qs_off + 1u],
            data_a[a_blk].qs[qs_off + 2u],
            data_a[a_blk].qs[qs_off + 3u]
        ));
        int32_t a_lo = pack_kvalues(qs_packed & 0x0F0F0F0Fu);
        int32_t a_hi = pack_kvalues((qs_packed >> 4u) & 0x0F0F0F0Fu);

        float dsb_x = float(data_b[b_ib].d);
        int32_t b_qs0 = data_b[b_ib].qs[b_qs_idx];
        int32_t b_qs1 = data_b[b_ib].qs[b_qs_idx + 4u];

        int32_t q_sum = dotPacked4x8EXT(a_lo, b_qs0) + dotPacked4x8EXT(a_hi, b_qs1);
        acc0 += da * float(q_sum) * dsb_x;
        i++;
    }

    float acc = subgroupAdd(acc0 + acc1 + acc2 + acc3);
    if (sub_tid == 0u) out_data[slot * uint(rows) + row] = acc;
}
