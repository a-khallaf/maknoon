#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_integer_dot_product : require
#extension GL_EXT_control_flow_attributes : enable

// Q6_K weights × Q8_1 input using dotPacked4x8EXT (dp4a).
// 128 threads, 2 rows per workgroup. 16 threads per super-block.
// Each thread handles 16 elements (one scale group = 4 dp4a calls).
//
// IMPORTANT: Q6_K blocks are 210 bytes (not divisible by 4).
// We MUST use uint16_t arrays (alignment 2) for the aliased struct,
// NOT uint32_t (alignment 4 would give stride 212, misaligning blocks).

layout(local_size_x = 128) in;

struct block_q6_k {
    uint8_t ql[128];
    uint8_t qh[64];
    int8_t scales[16];
    float16_t d;
};
struct block_q6_k_p16 {
    uint16_t ql[64];
    uint16_t qh[32];
    int8_t scales[16];
    float16_t d;
};

struct block_q8_1 {
    float16_t d;
    float16_t s;
    int32_t qs[8];
};

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(scalar, set = 0, binding = 1) readonly buffer A { block_q6_k data_a[]; };
layout(scalar, set = 0, binding = 1) readonly buffer AP16 { block_q6_k_p16 data_a_p16[]; };
layout(scalar, set = 0, binding = 2) readonly buffer B { block_q8_1 data_b[]; };

layout(push_constant) uniform Params {
    int rows;
    int cols;
};

#define NUM_ROWS 2
shared float tmpsh[NUM_ROWS][4];

uint load_u32_ql(uint ib, uint u16_idx) {
    return uint(data_a_p16[ib].ql[u16_idx]) | (uint(data_a_p16[ib].ql[u16_idx + 1u]) << 16);
}

uint load_u32_qh(uint ib, uint u16_idx) {
    return uint(data_a_p16[ib].qh[u16_idx]) | (uint(data_a_p16[ib].qh[u16_idx + 1u]) << 16);
}

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint first_row = gl_WorkGroupID.x * uint(NUM_ROWS);

    uint ncols = uint(cols);
    uint num_sb = ncols >> 8;

    uint num_rows = uint(NUM_ROWS);
    if (first_row + num_rows > uint(rows)) {
        num_rows = uint(rows) - first_row;
        if (first_row >= uint(rows)) return;
    }

    uint sg = tid & 15u;
    uint ix = tid >> 4;

    uint v_im = sg >> 3;
    uint pair = sg & 7u;
    uint q_block = pair >> 1;
    uint is_odd = pair & 1u;

    // ql uint16 index: v_im*32 + (q_block&1)*16 + is_odd*8
    // (each uint16 = 2 bytes, so divide byte offsets by 2)
    uint ql_u16_base = v_im * 32u + (q_block & 1u) * 16u + is_odd * 8u;
    uint ql_shift = (q_block >= 2u) ? 4u : 0u;

    // qh uint16 index: v_im*16 + is_odd*8
    uint qh_u16_base = v_im * 16u + is_odd * 8u;
    uint qh_shift = q_block * 2u;

    uint b_block_off = sg >> 1;
    uint b_half = sg & 1u;

    float temp[NUM_ROWS];
    [[unroll]] for (int r = 0; r < NUM_ROWS; r++) temp[r] = 0.0;

    for (uint i = ix; i < num_sb; i += 8u) {
        uint b_ib = i * 8u + b_block_off;
        int32_t cache_b[4];
        cache_b[0] = data_b[b_ib].qs[b_half * 4u];
        cache_b[1] = data_b[b_ib].qs[b_half * 4u + 1u];
        cache_b[2] = data_b[b_ib].qs[b_half * 4u + 2u];
        cache_b[3] = data_b[b_ib].qs[b_half * 4u + 3u];
        float d_b = float(data_b[b_ib].d);

        [[unroll]] for (uint n = 0; n < NUM_ROWS; n++) {
            uint ib = (first_row + n) * num_sb + i;

            float d_val = float(data_a[ib].d);
            float d_scale = d_val * float(data_a[ib].scales[sg]);

            int q_sum = 0;
            [[unroll]] for (uint j = 0; j < 4u; j++) {
                uint ql_v = (load_u32_ql(ib, ql_u16_base + j * 2u) >> ql_shift) & 0x0F0F0F0Fu;
                uint qh_v = (load_u32_qh(ib, qh_u16_base + j * 2u) >> qh_shift) & 0x03030303u;
                i32vec4 vals = i32vec4(unpack8(ql_v | (qh_v << 4))) - 32;
                int32_t packed = pack32(i8vec4(vals));
                q_sum += dotPacked4x8EXT(packed, cache_b[j]);
            }

            temp[n] += d_scale * float(q_sum) * d_b;
        }
    }

    [[unroll]] for (int r = 0; r < NUM_ROWS; r++) {
        temp[r] = subgroupAdd(temp[r]);
    }

    if (gl_SubgroupInvocationID == 0u) {
        [[unroll]] for (int r = 0; r < NUM_ROWS; r++) {
            tmpsh[r][gl_SubgroupID] = temp[r];
        }
    }
    barrier();

    if (tid == 0u) {
        [[unroll]] for (uint n = 0; n < num_rows; n++) {
            float sum = 0.0;
            [[unroll]] for (uint s = 0; s < gl_NumSubgroups; s++) {
                sum += tmpsh[n][s];
            }
            out_data[first_row + n] = sum;
        }
    }
}
