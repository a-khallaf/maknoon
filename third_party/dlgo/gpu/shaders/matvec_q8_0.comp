#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_control_flow_attributes : enable

// 128 threads = 4 subgroups. Each subgroup handles one row.
// 4x outer loop unrolling + separate accumulators for ILP.

layout(local_size_x = 128) in;

struct block_q8_0 {
    float16_t d;
    int8_t qs[32];
};

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(scalar, set = 0, binding = 1) readonly buffer A { block_q8_0 data_a[]; };
layout(set = 0, binding = 2) readonly buffer B { vec4 data_b_v4[]; };

layout(push_constant) uniform Params {
    int rows;
    int cols;
};

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint sub_id = tid >> 5;
    uint sub_tid = tid & 31u;
    uint row = gl_WorkGroupID.x * 4u + sub_id;
    uint pos_id = gl_WorkGroupID.y;

    if (row >= uint(rows)) return;

    uint ncols = uint(cols);
    uint x_off = pos_id * (ncols >> 2);
    uint out_off = pos_id * uint(rows);
    uint bpr = ncols >> 5;

    uint num_iters = ncols / 256u;
    if (num_iters * 256u + 8u * sub_tid < ncols) num_iters++;
    uint unrolled = num_iters & ~3u;

    float acc0 = 0.0, acc1 = 0.0, acc2 = 0.0, acc3 = 0.0;
    uint i = 0;

    while (i < unrolled) {
        [[unroll]] for (uint k = 0; k < 4u; k++) {
            uint col = (i + k) * 256u + 8u * sub_tid;
            uint ib = row * bpr + (col >> 5);
            uint iqs = col & 31u;
            float d = float(data_a[ib].d);

            vec4 bv0 = data_b_v4[x_off + (col >> 2)];
            vec4 bv1 = data_b_v4[x_off + (col >> 2) + 1u];

            vec4 v0 = vec4(float(data_a[ib].qs[iqs]), float(data_a[ib].qs[iqs+1u]),
                           float(data_a[ib].qs[iqs+2u]), float(data_a[ib].qs[iqs+3u]));
            vec4 v1 = vec4(float(data_a[ib].qs[iqs+4u]), float(data_a[ib].qs[iqs+5u]),
                           float(data_a[ib].qs[iqs+6u]), float(data_a[ib].qs[iqs+7u]));

            float r = d * (dot(bv0, v0) + dot(bv1, v1));
            if (k == 0u) acc0 += r; else if (k == 1u) acc1 += r;
            else if (k == 2u) acc2 += r; else acc3 += r;
        }
        i += 4u;
    }
    while (i < num_iters) {
        uint col = i * 256u + 8u * sub_tid;
        uint ib = row * bpr + (col >> 5);
        uint iqs = col & 31u;
        float d = float(data_a[ib].d);

        vec4 bv0 = data_b_v4[x_off + (col >> 2)];
        vec4 bv1 = data_b_v4[x_off + (col >> 2) + 1u];

        vec4 v0 = vec4(float(data_a[ib].qs[iqs]), float(data_a[ib].qs[iqs+1u]),
                       float(data_a[ib].qs[iqs+2u]), float(data_a[ib].qs[iqs+3u]));
        vec4 v1 = vec4(float(data_a[ib].qs[iqs+4u]), float(data_a[ib].qs[iqs+5u]),
                       float(data_a[ib].qs[iqs+6u]), float(data_a[ib].qs[iqs+7u]));

        acc0 += d * (dot(bv0, v0) + dot(bv1, v1));
        i++;
    }

    float acc = subgroupAdd(acc0 + acc1 + acc2 + acc3);
    if (sub_tid == 0u) out_data[out_off + row] = acc;
}
