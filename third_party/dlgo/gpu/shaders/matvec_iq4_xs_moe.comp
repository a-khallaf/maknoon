#version 450
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_KHR_shader_subgroup_arithmetic : require

// IQ4_XS MoE variant: no tables, expert_indices at binding 3.

layout(local_size_x = 128) in;

layout(push_constant) uniform Params {
    int rows;
    int cols;
    int expert_stride;
    int base_offset;
    int shared_input;
};

// IQ4_XS super-block: 136 bytes for 256 values
struct block_iq4_xs {
    float16_t d;
    uint8_t scales_h[2];
    uint8_t scales_l[4];
    uint8_t qs[128];
};

layout(binding = 0, scalar) buffer Out     { float out_data[]; };
layout(binding = 1, scalar) buffer Weights { block_iq4_xs blocks[]; };
layout(binding = 2, scalar) buffer X       { float x_data[];  };
layout(binding = 3, scalar) buffer Indices { float expert_indices[]; };

const int kvalues[16] = int[16](
    -127, -104, -83, -65, -49, -35, -22, -10,
    1, 13, 25, 38, 53, 69, 89, 113
);

shared float shared_sums[128];

void main() {
    const uint row_pair = gl_WorkGroupID.x;
    const uint tid = gl_LocalInvocationID.x;
    const uint slot = gl_WorkGroupID.y;
    const uint num_sb = uint(cols) / 256u;

    int eidx = int(expert_indices[slot]);
    uint expert_offset = uint(base_offset) + uint(eidx) * uint(expert_stride);
    uint pos_x_off = (shared_input != 0) ? 0u : (slot * uint(cols));

    for (uint n = 0u; n < 2u; n++) {
        uint row = row_pair * 2u + n;
        if (row >= uint(rows)) {
            if (n == 0u) out_data[slot * uint(rows) + row] = 0.0;
            continue;
        }

        float acc = 0.0;

        for (uint b = tid / 32u; b < num_sb; b += 4u) {
            uint bi = expert_offset + row * num_sb + b;
            float d = float(blocks[bi].d);
            uint lane = tid & 31u;

            uint scales_h_val = uint(blocks[bi].scales_h[0]) | (uint(blocks[bi].scales_h[1]) << 8u);

            uint ib32 = lane / 4u;
            uint il = lane & 3u;

            uint lo = (uint(blocks[bi].scales_l[ib32 / 2u]) >> (4u * (ib32 & 1u))) & 0xFu;
            uint hi = ((scales_h_val >> (2u * ib32)) & 3u) << 4u;
            float dl = d * float(int(lo | hi) - 32);

            uint qs_off = ib32 * 16u + il * 4u;
            uint x_base = b * 256u + ib32 * 32u;

            float sum = 0.0;
            for (uint j = 0u; j < 4u; j++) {
                uint qbyte = uint(blocks[bi].qs[qs_off + j]);
                float v_lo = dl * float(kvalues[qbyte & 0xFu]);
                float v_hi = dl * float(kvalues[qbyte >> 4u]);
                sum += v_lo * x_data[pos_x_off + x_base + il * 4u + j] + v_hi * x_data[pos_x_off + x_base + 16u + il * 4u + j];
            }

            acc += sum;
        }

        acc = subgroupAdd(acc);

        if ((tid & 31u) == 0u) {
            shared_sums[tid / 32u] = acc;
        }
        barrier();

        if (tid == 0u) {
            float total = 0.0;
            for (uint i = 0u; i < 4u; i++) {
                total += shared_sums[i];
            }
            out_data[slot * uint(rows) + row] = total;
        }
        barrier();
    }
}
