#version 450

layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer Data { float data_buf[]; };
layout(set = 0, binding = 1) readonly buffer Scale { float scale_buf[]; };

layout(push_constant) uniform Params {
    int total_n;  // total number of elements
    int dim;      // dimension to broadcast over (scale length)
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= uint(total_n)) return;
    data_buf[i] *= scale_buf[i % uint(dim)];
}
