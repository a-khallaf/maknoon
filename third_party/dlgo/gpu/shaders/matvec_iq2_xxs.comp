#version 450
#extension GL_KHR_shader_subgroup_arithmetic : enable
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types : require
#extension GL_EXT_scalar_block_layout : require
#extension GL_EXT_control_flow_attributes : enable

// IQ2_XXS: 66 bytes/block of 256 values.
// d(f16) + qs[64] (8 groups × 8 bytes).
// Each group: aux32[0] = 4 grid indices, aux32[1] = scale + sign indices.
// Grid lookup via SSBO binding 3: iq2xxs_grid[256] as uint[512], then ksigns[128] as uint[32].

layout(local_size_x = 128) in;

struct block_iq2_xxs {
    float16_t d;
    uint8_t qs[64];
};

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(scalar, set = 0, binding = 1) readonly buffer Weights { block_iq2_xxs blocks[]; };
layout(set = 0, binding = 2) readonly buffer X { float x_data[]; };
layout(set = 0, binding = 3) readonly buffer Tables { uint table_data[]; };

layout(push_constant) uniform Params {
    int rows;
    int cols;
};

#define NUM_ROWS 2
shared float tmpsh[NUM_ROWS][4];

#define KSIGNS_OFF 512u

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint first_row = gl_WorkGroupID.x * uint(NUM_ROWS);

    uint ncols = uint(cols);
    uint num_sb = ncols >> 8;

    uint num_rows = uint(NUM_ROWS);
    if (first_row + num_rows > uint(rows)) {
        num_rows = uint(rows) - first_row;
        if (first_row >= uint(rows)) return;
    }

    uint pos_id = gl_WorkGroupID.y;
    uint pos_x_off = pos_id * ncols;

    uint lane = tid & 31u;
    uint sb_group = tid >> 5;
    uint s = lane >> 3u;   // sub-group 0-3
    uint j = lane & 7u;    // element 0-7

    float temp[NUM_ROWS];
    [[unroll]] for (int r = 0; r < NUM_ROWS; r++) temp[r] = 0.0;

    for (uint b = sb_group; b < num_sb; b += 4u) {
        uint x_block = b * 256u;

        [[unroll]] for (uint n = 0; n < NUM_ROWS; n++) {
            uint bi = (first_row + n) * num_sb + b;
            float d = float(blocks[bi].d);

            float acc = 0.0;

            [[unroll]] for (uint ib32 = 0u; ib32 < 8u; ib32++) {
                uint qs_base = ib32 * 8u;

                uint aux1 = uint(blocks[bi].qs[qs_base + 4u])
                          | (uint(blocks[bi].qs[qs_base + 5u]) << 8u)
                          | (uint(blocks[bi].qs[qs_base + 6u]) << 16u)
                          | (uint(blocks[bi].qs[qs_base + 7u]) << 24u);

                float db = d * (0.5 + float(aux1 >> 28u)) * 0.25;

                uint grid_idx = uint(blocks[bi].qs[qs_base + s]);

                uint glo = table_data[grid_idx * 2u];
                uint ghi = table_data[grid_idx * 2u + 1u];
                uint grid_byte = j < 4u
                    ? (glo >> (j * 8u)) & 0xFFu
                    : (ghi >> ((j - 4u) * 8u)) & 0xFFu;
                float grid_val = float(grid_byte);

                uint sign_idx = (aux1 >> (7u * s)) & 127u;
                uint sign_word = table_data[KSIGNS_OFF + sign_idx / 4u];
                uint signs = (sign_word >> ((sign_idx & 3u) * 8u)) & 0xFFu;

                float val = ((signs & (1u << j)) != 0u) ? -db * grid_val : db * grid_val;

                acc += val * x_data[pos_x_off + x_block + ib32 * 32u + lane];
            }

            temp[n] += acc;
        }
    }

    [[unroll]] for (int r = 0; r < NUM_ROWS; r++) {
        temp[r] = subgroupAdd(temp[r]);
    }

    if (gl_SubgroupInvocationID == 0u) {
        [[unroll]] for (int r = 0; r < NUM_ROWS; r++) {
            tmpsh[r][gl_SubgroupID] = temp[r];
        }
    }
    barrier();

    if (tid == 0u) {
        [[unroll]] for (uint n = 0; n < num_rows; n++) {
            float sum = 0.0;
            [[unroll]] for (uint sv = 0; sv < gl_NumSubgroups; sv++) {
                sum += tmpsh[n][sv];
            }
            out_data[pos_id * uint(rows) + first_row + n] = sum;
        }
    }
}
