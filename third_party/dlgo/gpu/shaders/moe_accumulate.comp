#version 450

// Fused MoE accumulation: weighted sum of K expert outputs in one dispatch.
// out[i] = sum_e(weights[e] * exp_outs[e * dim + i])
// Replaces K serialized ScaleAdd dispatches + barriers.
//
// Optional fused per-expert down bias: when has_bias=1, adds
// bias[expert_id[e] * dim + i] to each expert output before weighting,
// eliminating a separate moe_bias_add dispatch + barrier.

layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer Out { float out_data[]; };
layout(set = 0, binding = 1) buffer ExpOuts { float exp_data[]; };
layout(set = 0, binding = 2) buffer Weights { float weights[]; };
layout(set = 0, binding = 3) buffer DownBias { float bias[]; };
layout(set = 0, binding = 4) buffer Indices { float expert_indices[]; };

layout(push_constant) uniform Params {
    int dim;
    int n_used;
    int has_bias;
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= uint(dim)) return;
    float sum = 0.0;
    if (has_bias != 0) {
        for (int e = 0; e < n_used; e++) {
            float val = exp_data[uint(e) * uint(dim) + i];
            int eidx = int(expert_indices[e]);
            val += bias[uint(eidx) * uint(dim) + i];
            sum += weights[e] * val;
        }
    } else {
        for (int e = 0; e < n_used; e++) {
            sum += weights[e] * exp_data[uint(e) * uint(dim) + i];
        }
    }
    out_data[i] = sum;
}
