#version 450

// SiLU (Swish) activation: x = x * sigmoid(x), in-place.
//
// Dispatch: groups_x = ceil(n / 256), groups_y = 1, groups_z = 1
// Buffers: 0=data (in-place)
// Push constants: n (4 bytes)

layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer Data { float data_buf[]; };

layout(push_constant) uniform Params {
    int n;
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= uint(n)) return;
    float x = data_buf[i];
    data_buf[i] = x / (1.0 + exp(-x));
}
