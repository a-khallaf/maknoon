#version 450

layout(local_size_x = 256) in;

layout(set = 0, binding = 0) buffer Out { float out_buf[]; };
layout(set = 0, binding = 1) readonly buffer Residual { float residual_buf[]; };
layout(set = 0, binding = 2) readonly buffer Data { float data_buf[]; };
layout(set = 0, binding = 3) readonly buffer Gate { float gate_buf[]; };

layout(push_constant) uniform Params {
    int total_n;
    int dim;
};

void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= uint(total_n)) return;
    out_buf[i] = residual_buf[i] + data_buf[i] * tanh(gate_buf[i % uint(dim)]);
}
